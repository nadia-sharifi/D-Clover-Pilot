{
  "name": "Novice Java (CLOVER)",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.java",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-java-test",
        "capstone-team-2.tu-clover@prerelease",
        // Prevent GitHub Copilot and other AI extensions from being installed
        "-GitHub.copilot",
        "-GitHub.copilot-chat",
        "-GitHub.copilot-labs",
        "-TabNine.tabnine-vscode",
        "-Codeium.codeium",
        "-VisualStudioExptTeam.vscodeintellicode"
      ],
      "settings": {
        // General Calm
        "telemetry.telemetryLevel": "off",
        "workbench.startupEditor": "none",
        "workbench.tips.enabled": false,
        "update.mode": "manual",
        "extensions.autoCheckUpdates": false,
        "extensions.autoUpdate": false,
        "extensions.ignoreRecommendations": true,
        "workbench.welcomePage.walkthroughs.openOnInstall": false,
        "notifications.showExtensionsRecommendations": false,
        "workbench.settings.enableNaturalLanguageSearch": false,

        // Hide UI Distractions
        "workbench.statusBar.visible": true,
        "workbench.activityBar.location": "top",
        "breadcrumbs.enabled": false,
        "editor.minimap.enabled": false,
        "explorer.openEditors.visible": 0,
        "scm.defaultViewMode": "list",
        "scm.showIncomingChanges": false,
        "workbench.view.alwaysShowHeaderActions": false,

        // Java Settings
        "java.configuration.updateBuildConfiguration": "automatic",
        "java.autobuild.enabled": true,
        "java.codeGeneration.useBlocks": true,
        "java.compile.nullAnalysis.mode": "automatic",
        // Hide default Java Run/Debug buttons (only show CLOVER's run button)
        "java.debug.settings.enableRunDebugCodeLens": false,

        // --- Comprehensive AI/Copilot Blocking ---
        // This is a multi-layered defense to prevent any AI features from running or being visible.

        // 1. Disable all Copilot functionality
        "github.copilot.enable": {
          "*": false, "plaintext": false, "markdown": false, "scminput": false, "java": false
        },
        "github.copilot.inlineSuggest.enable": false,
        "github.copilot.chat.enable": false,
        "github.copilot.editor.enableAutoCompletions": false,
        "github.copilot.editor.enableCodeActions": false,
        "github.copilot.renameSuggestions.triggerAutomatically": false,

        // 2. Hide all Copilot UI elements
        "github.copilot.statusBarItem": false,
        "github.copilot.chat.welcomeMessage": "never",
        "chat.setupHidden": true,
        "workbench.statusBar.feedback.visible": false,

        // 4. Block other common AI assistants
        "tabnine.disable_auto_update": true,
        "tabnine.binary_notification": false,
        "codeium.enableCodeLens": false,
        "codeium.enableConfig": false,
        "vsintellicode.modify.editor.suggestSelection": "off"
      }
    }
  },
  "postCreateCommand": null,
  "postAttachCommand": null,
  "hostRequirements": { "cpus": 2, "memory": "4gb" }
}

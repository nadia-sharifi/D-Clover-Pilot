{
  // Keep the UI sparse
  "workbench.editor.showTabs": "multiple",
  // students can switch files easily
  "workbench.panel.defaultLocation": "right",
  // panels out of the way
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.enablePersistentSessions": false,
  "git.enabled": false,
  // hide Git for the study
  "problems.showCurrentInStatus": false,
  // Editor comfort
  "editor.fontSize": 14,
  "editor.tabSize": 2,
  "editor.suggest.showWords": true,
  "editor.quickSuggestions": {
    "comments": "off",
    "strings": "off",
    "other": "off"
  },
  "editor.parameterHints.enabled": false,
  "editor.hover.enabled": false,
  "editor.codeActionsOnSave": {},
  // Java Settings
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.autobuild.enabled": true,
  // Hide default Java Run/Debug buttons (only show CLOVER's run button)
  "java.debug.settings.enableRunDebugCodeLens": false,
  // Comprehensive GitHub Copilot blocking and UI hiding
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "python": false,
    "java": false,
    "json": false,
    "jsonc": false
  },
  "chat.disableAIFeatures": true,
  // Hide status bar items that might show Copilot
  "workbench.statusBar.visible": true,
  "workbench.editor.enablePreview": false,
  // Hide chat/copilot setup completely
  "workbench.welcomePage.experimental.extensionContributions": false,
  "workbench.activityBar.iconClickBehavior": "focus",
  // Git/GitHub UI minimization
  "git.autofetch": false,
  "git.decorations.enabled": false,
  "git.countBadge": "off",
  "explorer.decorations.colors": false,
  "explorer.decorations.badges": false,
  // Testing UI minimization
  "testing.defaultGutterEnabled": false,
  "testing.automaticallyOpenPeekView": "never",
  "testing.openTesting": "never",
  // Hide remaining Git/SCM surfaces
  "scm.diffDecorations": "none",
  "scm.countBadge": "off",
  "git.showStatusBarSyncIcon": false,
  "timeline.excludeSources": [
    "git"
  ],
  "workbench.activityBar.location": "hidden",
  // Hide dotfiles from Explorer, Search, and file watchers
  "files.exclude": {
    "**/.*": true
  },
  "search.exclude": {
    "**/.*": true
  },
  "files.watcherExclude": {
    "**/.*": true
  },
  "clover.debug.apiUrl": "Dev API",
  "clover.classId": "c656fcdd-33ca-4101-b60a-e8b50664d0af",
  "clover.classCode": "1068",
  "clover.classTitle": "Java 1068",
  "clover.postSurveyId": "23fa7450-dfcd-4fe4-a050-d21056d6e9e3",
  "clover.preSurveyId": "2c47cac0-9d51-403a-9e46-776682a8af19",
  "clover.debug.apiVersion": "v2",
  "testing.automaticallyOpenTestResults": "never"
}
